    <worksheet name='Colour Progress KPI'>
      <repository-location id='ColourProgressKPI' path='/workbooks/EnglandRecyclingWasteDashboard3' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='ExportAuthorityLocationsLookup.csv+ (Multiple Connections)' name='federated.0bog5zv16krskr1et8elj1f3ggxh' />
          </datasources>
          <datasource-dependencies datasource='federated.0bog5zv16krskr1et8elj1f3ggxh'>
            <column caption='Positive Colour' datatype='integer' name='[Calculation_0880729046175745]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_1901350520201220] &gt;= 0 THEN 1&#13;&#10;ELSEIF [Calculation_1901350520201220] &lt; 0 THEN -1&#13;&#10;END' />
            </column>
            <column caption='First Period' datatype='real' name='[Calculation_1185018707480576]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [period_start] =&#13;&#10;            { FIXED : MIN([period_start]) }&#13;&#10;        THEN [total_tonnes]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Last Period' datatype='real' name='[Calculation_1185018707775489]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [period_end] =&#13;&#10;            { FIXED : MAX([period_end]) }&#13;&#10;        THEN [total_tonnes]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Recycling Progress through Periods' datatype='real' name='[Calculation_1901350520201220]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;    [Calculation_1185018707775489] - [Calculation_1185018707480576]&#13;&#10;)&#13;&#10;/&#13;&#10;[Calculation_1185018707480576]' />
            </column>
            <column caption='Lad25cd' datatype='string' name='[LAD25CD]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0880729046175745]' derivation='None' name='[none:Calculation_0880729046175745:qk]' pivot='key' type='quantitative' />
            <column-instance column='[LAD25CD]' derivation='None' name='[none:LAD25CD:nk]' pivot='key' type='nominal' />
            <column caption='Period End' datatype='date' name='[period_end]' role='dimension' type='ordinal' />
            <column caption='Period Start' datatype='date' name='[period_start]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1901350520201220]' derivation='Sum' name='[sum:Calculation_1901350520201220:qk]' pivot='key' type='quantitative' />
            <column caption='Total Tonnes' datatype='real' name='[total_tonnes]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <slices>
            <column>[federated.0bog5zv16krskr1et8elj1f3ggxh].[none:LAD25CD:nk]</column>
          </slices>
