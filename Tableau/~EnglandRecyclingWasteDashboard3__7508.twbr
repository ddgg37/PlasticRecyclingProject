      <column caption='Bng E' datatype='integer' name='[BNG_E]' role='measure' type='quantitative' />
      <column caption='Bng N' datatype='integer' name='[BNG_N]' role='measure' type='quantitative' />
      <column caption='Recycled Material Per Habitant' datatype='real' name='[Calculation_0266651495632896]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_tonnes])/[Calculation_1593211915333632]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='Sum' caption='Colour Progress' datatype='integer' name='[Calculation_0880729040277504]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Calculation_1901350520201220] &gt;= 0 THEN 1&#13;&#10;ELSE -1&#13;&#10;END' />
      </column>
      <column caption='Positive Colour' datatype='integer' name='[Calculation_0880729046175745]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1901350520201220] &gt;= 0 THEN 1&#13;&#10;ELSEIF [Calculation_1901350520201220] &lt; 0 THEN -1&#13;&#10;END' />
      </column>
      <column caption='First Period' datatype='real' name='[Calculation_1185018707480576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [period_start] =&#13;&#10;            { FIXED : MIN([period_start]) }&#13;&#10;        THEN [total_tonnes]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Last Period' datatype='real' name='[Calculation_1185018707775489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [period_end] =&#13;&#10;            { FIXED : MAX([period_end]) }&#13;&#10;        THEN [total_tonnes]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='RANK Top Recycling Authorities' datatype='integer' name='[Calculation_1278751654174720]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(MAX([tonnes_by_material]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='England Population' datatype='integer' name='[Calculation_1593211915333632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM(SUM([population]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Authority Population %' datatype='real' name='[Calculation_1593211915513857]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([population])/[Calculation_1593211915333632]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Label KPI England Population' datatype='string' name='[Calculation_1901350481113088]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;England Population&apos;' />
      </column>
      <column caption='Label KPI Recycled Material Habitant' datatype='string' name='[Calculation_1901350482321410]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;% Recycling per Habitant&apos;' />
      </column>
      <column caption='Max Tonnes Authority per Capita' datatype='real' name='[Calculation_1901350495891459]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([tonnes_by_material]) * [Calculation_1593211915513857]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Recycling Progress through Periods' datatype='real' name='[Calculation_1901350520201220]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;    [Calculation_1185018707775489] - [Calculation_1185018707480576]&#13;&#10;)&#13;&#10;/&#13;&#10;[Calculation_1185018707480576]' />
      </column>
      <column caption='Material Tonnes Recycling Rate 100' datatype='real' name='[Calculation_1934610354950145]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([tonnes_by_material])/[Calculation_1593211915333632] * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='RANK Recycling Materials' datatype='integer' name='[Calculation_1934610357551106]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE([Calculation_1934610354950145])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
