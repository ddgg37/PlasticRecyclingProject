      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0bog5zv16krskr1et8elj1f3ggxh].[ctd:LAD25CD:qk]&quot;' value='# Authorities' />
          <alias key='&quot;[federated.0bog5zv16krskr1et8elj1f3ggxh].[ctd:material_group:qk]&quot;' value='# Material Groups' />
