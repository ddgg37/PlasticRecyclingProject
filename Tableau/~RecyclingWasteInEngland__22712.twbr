  <worksheets>
    <worksheet name='Best Recycling Tonnes by Authorities'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>Highest Recycling Rate per Capita</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='ExportAuthorityLocationsLookup.csv+ (Multiple Connections)' name='federated.1m9n5j70xx3dwz1c3d7li0r358ba' />
          </datasources>
          <datasource-dependencies datasource='federated.1m9n5j70xx3dwz1c3d7li0r358ba'>
            <column caption='Recycling Flag' datatype='string' name='[Calculation_0348292427837440]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Calculated Field: Recycling Flag&#13;&#10;CASE [facility_type]&#13;&#10;    WHEN &apos;Reprocessor - recycling (qu19)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Exporter - recycling (qu19)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Reuse (qu35)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Exporter - reuse (qu35)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Windrow or other composting&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;In vessel composting&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Anaerobic or Aerobic Digestion Segregated&apos; THEN &apos;Recycled&apos;&#13;&#10;    ELSE &apos;Not Recycled&apos;&#13;&#10;END' />
            </column>
            <column caption='Population per Authority' datatype='integer' name='[Calculation_1398601129099265]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Population per Authority&#13;&#10;{FIXED [authority_id]: &#13;&#10;    MIN([population])&#13;&#10;}' />
            </column>
            <column caption='Recycled Tonnes per Authority' datatype='real' name='[Calculation_1398601129349122]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Recycled Tonnes per Authority&#13;&#10;{ FIXED [authority_id] : &#13;&#10;    SUM(IF [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END) &#13;&#10;}' />
            </column>
            <column caption='Recycled Tonnes per Capita' datatype='real' name='[Calculation_1398601129730051]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Recycled Tonnes per Capita&#13;&#10;[Calculation_1398601129349122] / [Calculation_1398601129099265]' />
            </column>
            <column caption='Top 10 Best Recycled Tonnes per Authority' datatype='boolean' name='[Calculation_1462922688262144]' role='measure' type='nominal'>
              <calculation class='tableau' formula='// Top and Bottom N Filter&#13;&#10;RANK(SUM([Calculation_1398601129349122]), &apos;desc&apos;) &lt;= 10'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Authority Id' datatype='integer' name='[authority_id]' role='dimension' type='ordinal' />
            <column caption='Authority Name' datatype='string' name='[authority_name]' role='dimension' type='nominal' />
            <column caption='Facility Type' datatype='string' name='[facility_type]' role='dimension' type='nominal' />
            <column caption='Geography Type' datatype='string' name='[geography_type]' role='dimension' type='nominal' />
            <column caption='Location Code' datatype='string' name='[location_code]' role='dimension' type='nominal' />
            <column-instance column='[authority_id]' derivation='None' name='[none:authority_id:ok]' pivot='key' type='ordinal' />
            <column-instance column='[authority_name]' derivation='None' name='[none:authority_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[facility_type]' derivation='None' name='[none:facility_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[geography_type]' derivation='None' name='[none:geography_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[location_code]' derivation='None' name='[none:location_code:nk]' pivot='key' type='nominal' />
            <column caption='Population' datatype='integer' name='[population]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1398601129099265]' derivation='Sum' name='[sum:Calculation_1398601129099265:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1398601129730051]' derivation='Sum' name='[sum:Calculation_1398601129730051:qk]' pivot='key' type='quantitative' />
            <column caption='Tonnes By Material' datatype='real' name='[tonnes_by_material]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1462922688262144]' derivation='User' name='[usr:Calculation_1462922688262144:nk:2]' pivot='key' type='nominal'>
              <table-calc ordering-field='[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[authority_id]' ordering-type='Field' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[usr:Calculation_1462922688262144:nk:2]'>
            <groupfilter function='member' level='[usr:Calculation_1462922688262144:nk:2]' member='true' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
