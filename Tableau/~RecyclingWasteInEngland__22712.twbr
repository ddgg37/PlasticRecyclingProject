    <worksheet name='Recycling Route Mix'>
      <table>
        <view>
          <datasources>
            <datasource caption='ExportAuthorityLocationsLookup.csv+ (Multiple Connections)' name='federated.1m9n5j70xx3dwz1c3d7li0r358ba' />
          </datasources>
          <datasource-dependencies datasource='federated.1m9n5j70xx3dwz1c3d7li0r358ba'>
            <column caption='Route Category' datatype='string' name='[Calculation_1398601125982208]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Route Category (for stacked route-mix chart)&#13;&#10;CASE [facility_type]&#13;&#10;    WHEN &apos;Reprocessor - recycling (qu19)&apos; THEN &apos;Recycling&apos;&#13;&#10;    WHEN &apos;Exporter - recycling (qu19)&apos; THEN &apos;Recycling&apos;&#13;&#10;    WHEN &apos;Reuse (qu35)&apos; THEN &apos;Reuse&apos;&#13;&#10;    WHEN &apos;Exporter - reuse (qu35)&apos; THEN &apos;Reuse&apos;&#13;&#10;    WHEN &apos;Windrow or other composting&apos; THEN &apos;Composting / AD&apos;&#13;&#10;    WHEN &apos;In vessel composting&apos; THEN &apos;Composting / AD&apos;&#13;&#10;    WHEN &apos;Anaerobic or Aerobic Digestion Segregated&apos; THEN &apos;Composting / AD&apos;&#13;&#10;    WHEN &apos;Incineration with energy recovery&apos; THEN &apos;Energy Recovery&apos;&#13;&#10;    WHEN &apos;RDF, autoclave, MHT or similar&apos; THEN &apos;Energy Recovery&apos;&#13;&#10;    WHEN &apos;Non-hazardous landfill&apos; THEN &apos;Landfill&apos;&#13;&#10;    WHEN &apos;Hazardous landfill&apos; THEN &apos;Landfill&apos;&#13;&#10;    WHEN &apos;Inert landfill&apos; THEN &apos;Landfill&apos;&#13;&#10;    WHEN &apos;Incineration without energy recovery&apos; THEN &apos;Incineration (no recovery)&apos;&#13;&#10;    ELSE &apos;Other / Intermediate&apos;&#13;&#10;END' />
            </column>
            <column caption='Facility Type' datatype='string' name='[facility_type]' role='dimension' type='nominal' />
            <column caption='Geography Type' datatype='string' name='[geography_type]' role='dimension' type='nominal' />
            <column caption='Location Code' datatype='string' name='[location_code]' role='dimension' type='nominal' />
            <column caption='Material' datatype='string' name='[material]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1398601125982208]' derivation='None' name='[none:Calculation_1398601125982208:nk]' pivot='key' type='nominal' />
            <column-instance column='[facility_type]' derivation='None' name='[none:facility_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[geography_type]' derivation='None' name='[none:geography_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[location_code]' derivation='None' name='[none:location_code:nk]' pivot='key' type='nominal' />
