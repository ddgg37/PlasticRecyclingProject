            <zone fixed-size='330' friendly-name='VC-KPI-right' h='12539' id='9' is-fixed='true' param='vert' type-v2='layout-flow' w='24158' x='74745' y='11029' />
            <zone-style>
              <format attr='border-color' value='#c0c0c0' />
