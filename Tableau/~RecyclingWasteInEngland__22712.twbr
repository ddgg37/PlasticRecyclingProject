            <column-instance column='[tonnes_by_material]' derivation='Sum' name='[pcto:sum:tonnes_by_material:qk:3]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[material]' ordering-type='Field' type='PctTotal' />
