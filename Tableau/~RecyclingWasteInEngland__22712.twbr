      <column caption='Total Population' datatype='integer' name='[Calculation_0317781034274817]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total Population (all authorities, filter-immune)&#13;&#10;{ FIXED [geography_type]:&#13;&#10;    SUM(&#13;&#10;        {FIXED [authority_id]: &#13;&#10;            MIN([population])&#13;&#10;        }&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Total Recycled Tonnes by Material' datatype='real' name='[Calculation_0317781036371970]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total Recycled Tonnes for all years&#13;&#10;{FIXED: &#13;&#10;    SUM(&#13;&#10;        IF [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Recycling Flag' datatype='string' name='[Calculation_0348292427837440]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Calculated Field: Recycling Flag&#13;&#10;CASE [facility_type]&#13;&#10;    WHEN &apos;Reprocessor - recycling (qu19)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Exporter - recycling (qu19)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Reuse (qu35)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Exporter - reuse (qu35)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Windrow or other composting&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;In vessel composting&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Anaerobic or Aerobic Digestion Segregated&apos; THEN &apos;Recycled&apos;&#13;&#10;    ELSE &apos;Not Recycled&apos;&#13;&#10;END' />
      </column>
      <column caption='Recycling Rate' datatype='real' name='[Calculation_0348292428730369]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Calculated Field: Recycling Rate&#13;&#10;SUM(IF [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END)&#13;&#10;/&#13;&#10;SUM([tonnes_by_material])' />
      </column>
      <column caption='Recycling Rate 2023' datatype='real' name='[Calculation_0348292429230082]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Recycling Rate 2023&#13;&#10;{ FIXED : &#13;&#10;    SUM(IF YEAR([period_start]) = 2023 AND [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END)&#13;&#10;    / SUM(IF YEAR([period_start]) = 2023 THEN [tonnes_by_material] END)&#13;&#10;}' />
      </column>
      <column caption='Recycling Rate 2024' datatype='real' name='[Calculation_0348292429565955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Recycling Rate 2024&#13;&#10;{ FIXED : &#13;&#10;    SUM(IF YEAR([period_start]) = 2024 AND [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END)&#13;&#10;    / SUM(IF YEAR([period_start]) = 2024 THEN [tonnes_by_material] END)&#13;&#10;}' />
      </column>
      <column caption='Recycling Rate 2025' datatype='real' name='[Calculation_0348292429697028]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Recycling Rate 2025&#13;&#10;{ FIXED : &#13;&#10;    SUM(IF YEAR([period_start]) = 2025 AND [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END)&#13;&#10;    / SUM(IF YEAR([period_start]) = 2025 THEN [tonnes_by_material] END)&#13;&#10;}' />
      </column>
      <column caption='Change Rate 24-25' datatype='real' name='[Calculation_0348292429856773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Change 2024 → 2025&#13;&#10;[Calculation_0348292429697028] - [Calculation_0348292429565955]' />
      </column>
      <column caption='Change Rate 23-24' datatype='real' name='[Calculation_0348292430061574]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Change 2023 → 2024&#13;&#10;[Calculation_0348292429565955] - [Calculation_0348292429230082]' />
      </column>
      <column caption='Total Tonnes All Periods' datatype='real' name='[Calculation_0348292431536135]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED YEAR([period_start]) :&#13;&#10;    SUM(&#13;&#10;        IF [period_start] =&#13;&#10;            { FIXED YEAR([period_start]) : MIN([period_start]) }&#13;&#10;        THEN [total_tonnes]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Route Category' datatype='string' name='[Calculation_1398601125982208]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Route Category (for stacked route-mix chart)&#13;&#10;CASE [facility_type]&#13;&#10;    WHEN &apos;Reprocessor - recycling (qu19)&apos; THEN &apos;Recycling&apos;&#13;&#10;    WHEN &apos;Exporter - recycling (qu19)&apos; THEN &apos;Recycling&apos;&#13;&#10;    WHEN &apos;Reuse (qu35)&apos; THEN &apos;Reuse&apos;&#13;&#10;    WHEN &apos;Exporter - reuse (qu35)&apos; THEN &apos;Reuse&apos;&#13;&#10;    WHEN &apos;Windrow or other composting&apos; THEN &apos;Composting / AD&apos;&#13;&#10;    WHEN &apos;In vessel composting&apos; THEN &apos;Composting / AD&apos;&#13;&#10;    WHEN &apos;Anaerobic or Aerobic Digestion Segregated&apos; THEN &apos;Composting / AD&apos;&#13;&#10;    WHEN &apos;Incineration with energy recovery&apos; THEN &apos;Energy Recovery&apos;&#13;&#10;    WHEN &apos;RDF, autoclave, MHT or similar&apos; THEN &apos;Energy Recovery&apos;&#13;&#10;    WHEN &apos;Non-hazardous landfill&apos; THEN &apos;Landfill&apos;&#13;&#10;    WHEN &apos;Hazardous landfill&apos; THEN &apos;Landfill&apos;&#13;&#10;    WHEN &apos;Inert landfill&apos; THEN &apos;Landfill&apos;&#13;&#10;    WHEN &apos;Incineration without energy recovery&apos; THEN &apos;Incineration (no recovery)&apos;&#13;&#10;    ELSE &apos;Other / Intermediate&apos;&#13;&#10;END' />
      </column>
      <column caption='Population per Authority' datatype='integer' name='[Calculation_1398601129099265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Population per Authority&#13;&#10;{FIXED [authority_id]: &#13;&#10;    MIN([population])&#13;&#10;}' />
      </column>
      <column caption='Recycled Tonnes per Authority' datatype='real' name='[Calculation_1398601129349122]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Recycled Tonnes per Authority&#13;&#10;{ FIXED [authority_id] : &#13;&#10;    SUM(IF [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END) &#13;&#10;}' />
      </column>
      <column caption='Recycled Tonnes per Capita' datatype='real' name='[Calculation_1398601129730051]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Recycled Tonnes per Capita&#13;&#10;[Calculation_1398601129349122] / [Calculation_1398601129099265]' />
      </column>
      <column caption='Total Facilities' datatype='integer' name='[Calculation_1398601130909700]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total Facilities (distinct count)&#13;&#10;{ FIXED : COUNTD([national_facility_id]) }' />
      </column>
      <column caption='Total Authorities' datatype='integer' name='[Calculation_1398601134276613]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total Authorities (distinct)&#13;&#10;{ FIXED : COUNTD([authority_id]) }' />
      </column>
      <column caption='Rate Colour 23-24' datatype='string' name='[Calculation_1398601139654662]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Rate Change Color (2023-&gt;2024 tile)&#13;&#10;IF [Calculation_0348292430061574] &gt;= 0 THEN &quot;Positive&quot; ELSE &quot;Negative&quot; END' />
      </column>
      <column caption='Rate Colour 24-25' datatype='string' name='[Calculation_1398601139867655]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Rate Change Color (2024-&gt;2025 tile)&#13;&#10;IF [Calculation_0348292429856773] &gt;= 0 THEN &quot;Positive&quot; ELSE &quot;Negative&quot; END' />
      </column>
      <column caption='Total Recycled Tonnes' datatype='real' name='[Calculation_1398601152806920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END)' />
      </column>
      <column caption='Top 10 Best Recycled Tonnes per Authority' datatype='boolean' name='[Calculation_1462922688262144]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// Top and Bottom N Filter&#13;&#10;RANK(SUM([Calculation_1398601129349122]), &apos;desc&apos;) &lt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Tot Recycles Tonnes' datatype='boolean' name='[Calculation_1462922700578819]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1398601152806920]&gt;= WINDOW_AVG([Calculation_1398601152806920])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 10 Worst Recycled Tonnes per Authority' datatype='boolean' name='[Top 10 BestWorst Recycled Tonnes per Authority (copy)_1690796689534976]' role='measure' type='nominal'>
        <calculation class='tableau' formula='//Bottom N Filter&#13;&#10;RANK(SUM([Calculation_1398601129349122]), &apos;asc&apos;) &lt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
