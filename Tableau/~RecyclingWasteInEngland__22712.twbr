    <dashboard enable-sort-zone-taborder='true' name='Seasonal Material'>
      <style />
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' preset-index='0' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='13430' id='3' param='horz' type-v2='layout-flow' w='100000' x='0' y='0'>
            <zone forceUpdate='true' h='10566' id='6' type-v2='text' w='98390' x='805' y='1432'>
              <formatted-text>
                <run bold='true' fontalignment='1' fontcolor='#000000' fontsize='15'>When the Calendar Drives the Numbers - Seasonal Material behaviour</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone-style>
              <format attr='border-color' value='#c0c0c0' />
              <format attr='border-style' value='solid' />
              <format attr='border-width' value='1' />
              <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='5' />
              <format attr='margin' value='5' />
              <format attr='padding' value='5' />
              <format attr='background-color' value='#ffffff' />
            </zone-style>
          </zone>
          <zone h='86570' id='5' param='horz' type-v2='layout-flow' w='100000' x='0' y='13430'>
            <zone h='86570' id='11' param='vert' type-v2='layout-flow' w='45790' x='0' y='13430'>
              <zone fixed-size='625' forceUpdate='true' h='81380' id='10' is-fixed='true' type-v2='text' w='44180' x='805' y='14862'>
                <formatted-text>
                  <run fontcolor='#000000' fontsize='10'>Garden waste tells a story about the seasons, not about recycling performance. Every single year, without exception, tonnage peaks in April–June — the growing season — and falls to roughly a third of that peak by January–March, a swing of about 66%. And unlike some of the other materials, there&apos;s no meaningful year-over-year trend underneath this pattern — it&apos;s purely seasonal, rising and falling with the weather, not improving or declining. This chapter exists to draw a clear line: not every big swing in the data means something changed — sometimes it just means the seasons turned.</run>
                </formatted-text>
                <zone-style>
                  <format attr='border-color' value='#000000' />
                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='0' />
                  <format attr='background-color' value='#ffffff' />
                </zone-style>
              </zone>
              <zone-style>
                <format attr='border-color' value='#c0c0c0' />
                <format attr='border-style' value='solid' />
                <format attr='border-width' value='1' />
                <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='5' />
                <format attr='margin' value='5' />
                <format attr='padding' value='5' />
                <format attr='background-color' value='#ffffff' />
              </zone-style>
            </zone>
            <zone h='86570' id='12' param='vert' type-v2='layout-flow' w='54209' x='45790' y='13430'>
              <zone h='83706' id='9' name='Seasonal Materials' w='52599' x='46595' y='14862'>
                <layout-cache minheight='180' minwidth='187' type-h='scalable' type-w='scalable' />
                <zone-style>
                  <format attr='border-color' value='#000000' />
                  <format attr='border-style' value='none' />
                  <format attr='border-width' value='0' />
                  <format attr='margin' value='0' />
                  <format attr='background-color' value='#ffffff' />
                </zone-style>
              </zone>
              <zone-style>
                <format attr='border-color' value='#c0c0c0' />
                <format attr='border-style' value='solid' />
                <format attr='border-width' value='1' />
                <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='5' />
                <format attr='margin' value='5' />
                <format attr='padding' value='5' />
                <format attr='background-color' value='#ffffff' />
              </zone-style>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
