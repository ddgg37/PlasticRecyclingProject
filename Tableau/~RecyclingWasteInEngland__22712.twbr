    <worksheet name='Sheet 1'>
      <table>
        <view>
          <datasources>
            <datasource caption='ExportAuthorityLocationsLookup.csv+ (Multiple Connections)' name='federated.1m9n5j70xx3dwz1c3d7li0r358ba' />
          </datasources>
          <datasource-dependencies datasource='federated.1m9n5j70xx3dwz1c3d7li0r358ba'>
            <column caption='Total Population' datatype='integer' name='[Calculation_0317781034274817]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Total Population (all authorities, filter-immune)&#13;&#10;{ FIXED [geography_type]:&#13;&#10;    SUM(&#13;&#10;        {FIXED [authority_id]: &#13;&#10;            MIN([population])&#13;&#10;        }&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Total Recycled Tonnes by Material' datatype='real' name='[Calculation_0317781036371970]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Total Recycled Tonnes for all years&#13;&#10;{FIXED: &#13;&#10;    SUM(&#13;&#10;        IF [Calculation_0348292427837440] = &apos;Recycled&apos; THEN [tonnes_by_material] END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Recycling Flag' datatype='string' name='[Calculation_0348292427837440]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Calculated Field: Recycling Flag&#13;&#10;CASE [facility_type]&#13;&#10;    WHEN &apos;Reprocessor - recycling (qu19)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Exporter - recycling (qu19)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Reuse (qu35)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Exporter - reuse (qu35)&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Windrow or other composting&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;In vessel composting&apos; THEN &apos;Recycled&apos;&#13;&#10;    WHEN &apos;Anaerobic or Aerobic Digestion Segregated&apos; THEN &apos;Recycled&apos;&#13;&#10;    ELSE &apos;Not Recycled&apos;&#13;&#10;END' />
            </column>
            <column caption='Total Tonnes All Periods' datatype='real' name='[Calculation_0348292431536135]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED YEAR([period_start]) :&#13;&#10;    SUM(&#13;&#10;        IF [period_start] =&#13;&#10;            { FIXED YEAR([period_start]) : MIN([period_start]) }&#13;&#10;        THEN [total_tonnes]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='Authority Id' datatype='integer' name='[authority_id]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_0317781036371970]' derivation='Sum' name='[cum:sum:Calculation_0317781036371970:ok]' pivot='key' type='ordinal'>
              <table-calc aggregation='Sum' ordering-type='Columns' type='CumTotal' />
            </column-instance>
            <column caption='Facility Type' datatype='string' name='[facility_type]' role='dimension' type='nominal' />
            <column caption='Geography Type' datatype='string' name='[geography_type]' role='dimension' type='nominal' />
            <column caption='Location Code' datatype='string' name='[location_code]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0348292427837440]' derivation='None' name='[none:Calculation_0348292427837440:nk]' pivot='key' type='nominal' />
            <column-instance column='[facility_type]' derivation='None' name='[none:facility_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[geography_type]' derivation='None' name='[none:geography_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[location_code]' derivation='None' name='[none:location_code:nk]' pivot='key' type='nominal' />
            <column caption='Period Start' datatype='date' name='[period_start]' role='dimension' type='ordinal' />
            <column caption='Population' datatype='integer' name='[population]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0317781034274817]' derivation='Sum' name='[sum:Calculation_0317781034274817:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_0348292431536135]' derivation='Sum' name='[sum:Calculation_0348292431536135:ok]' pivot='key' type='ordinal' />
            <column-instance column='[population]' derivation='Sum' name='[sum:population:qk]' pivot='key' type='quantitative' />
            <column-instance column='[tonnes_by_material]' derivation='Sum' name='[sum:tonnes_by_material:qk]' pivot='key' type='quantitative' />
            <column caption='Tonnes By Material' datatype='real' name='[tonnes_by_material]' role='measure' type='quantitative' />
            <column caption='Total Tonnes' datatype='real' name='[total_tonnes]' role='measure' type='quantitative' />
            <column-instance column='[period_start]' derivation='Year' name='[yr:period_start:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[:Measure Names]'>
            <groupfilter function='union' user:op='manual'>
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[sum:population:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[sum:tonnes_by_material:qk]&quot;' />
