            <column>[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[none:facility_type:nk]</column>
            <column>[federated.1m9n5j70xx3dwz1c3d7li0r358ba].[usr:Calculation_1462922688262144:nk:2]</column>
          </slices>
          <aggregation value='true' />
